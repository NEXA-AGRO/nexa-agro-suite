{
  "name": "nexa-agro-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/nexa-agro-web",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project nexa-agro-web --web",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/nexa-agro-web"
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "nexa-agro-web:build",
        "dev": true
      }
    }
  }
}
